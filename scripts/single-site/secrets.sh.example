#!/bin/bash
# Copy this file to secrets.sh and fill in your values.
# secrets.sh is excluded from git — never commit real values.

# The Pantheon site machine name (found in the Site Dashboard URL or terminus site:list)
export SITE_NAME="my-site-name"

# Used by db-search-replace.sh only
export WP_SEARCH="https://old-domain.com"
export WP_REPLACE="https://new-domain.com"
